<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>

<VBox spacing="15"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.blackjack.BlackjackController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Money:"/>
        <Label fx:id="fxMoneyLabel"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Bet:"/>
        <TextField fx:id="fxBetField" prefWidth="80"/>
        <Button text="New Round"
                fx:id="fxNewRoundBtn"
                onAction="#onNewRound"/>
    </HBox>

    <VBox spacing="5" alignment="CENTER">
        <Label text="Dealer"/>
        <Label fx:id="fxDealerHandLabel"/>
        <Label fx:id="fxDealerValueLabel"/>
    </VBox>

    <VBox spacing="5" alignment="CENTER">
        <Label text="Player"/>
        <Label fx:id="fxPlayerHandLabel"/>
        <Label fx:id="fxPlayerValueLabel"/>
    </VBox>

    <Label fx:id="fxStatusLabel"/>

    <HBox spacing="15" alignment="CENTER">
        <Button text="Hit"
                fx:id="fxHitBtn"
                onAction="#onHit"/>
        <Button text="Stand"
                fx:id="fxStandBtn"
                onAction="#onStand"/>
        <Button text="Double"
                fx:id="fxDoubleBtn"
                onAction="#onDouble"/>
    </HBox>

</VBox>
